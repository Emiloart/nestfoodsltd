# App
APP_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_APP_HOSTS=admin.localhost:3000,admin.nestfoodsltd.com
NEXT_PUBLIC_DEFAULT_CURRENCY=NGN
NEXT_PUBLIC_DEFAULT_LOCALE=en-NG

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestfoodsltd

# Auth
AUTH_SECRET=replace-with-strong-secret
ADMIN_TOKEN_SUPER_ADMIN=replace-with-super-admin-token
ADMIN_TOKEN_CONTENT_EDITOR=replace-with-content-editor-token
ADMIN_TOKEN_SALES_MANAGER=replace-with-sales-manager-token

# CMS Storage
CMS_STORAGE_DRIVER=json

# Admin Users Storage
ADMIN_USERS_STORAGE_DRIVER=json

# Commerce Storage
COMMERCE_STORAGE_DRIVER=json

# Customer Storage
CUSTOMER_STORAGE_DRIVER=json

# Chat Storage
CHAT_STORAGE_DRIVER=json

# B2B Storage
B2B_STORAGE_DRIVER=json

# Traceability Storage
TRACEABILITY_STORAGE_DRIVER=json

# Recipes Storage
RECIPES_STORAGE_DRIVER=json

# Audit Storage
AUDIT_LOG_STORAGE_DRIVER=json

# Privacy Storage
PRIVACY_STORAGE_DRIVER=json

# Observability Storage
OBSERVABILITY_STORAGE_DRIVER=json

# Payments
PAYMENT_MODE=mock
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
FLW_WEBHOOK_SECRET_HASH=
FLW_REDIRECT_URL=

# Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Observability + Analytics
SENTRY_DSN=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Storage / Media
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
