APP_ENV=staging
NEXT_PUBLIC_SITE_URL=https://staging.nestfoodsltd.com
ADMIN_APP_HOSTS=admin.staging.nestfoodsltd.com
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/nestfoodsltd
AUTH_SECRET=replace-with-strong-secret
ADMIN_TOKEN_SUPER_ADMIN=replace-with-super-admin-token
ADMIN_TOKEN_CONTENT_EDITOR=replace-with-content-editor-token
ADMIN_TOKEN_SALES_MANAGER=replace-with-sales-manager-token

CMS_STORAGE_DRIVER=postgres
COMPANY_STORAGE_DRIVER=postgres
CATALOG_STORAGE_DRIVER=postgres
ADMIN_USERS_STORAGE_DRIVER=postgres
CHAT_STORAGE_DRIVER=postgres
AUDIT_LOG_STORAGE_DRIVER=postgres
PRIVACY_STORAGE_DRIVER=postgres
NEWSLETTER_STORAGE_DRIVER=postgres
ENQUIRIES_STORAGE_DRIVER=postgres
CAREERS_STORAGE_DRIVER=postgres
OBSERVABILITY_STORAGE_DRIVER=postgres

EMAIL_PROVIDER=resend
RESEND_API_KEY=replace-with-resend-api-key
EMAIL_FROM="De-Nest Bread <noreply@nestfoodsltd.com>"
EMAIL_REPLY_TO=info@nestfoodsltd.com
SALES_NOTIFICATION_EMAIL=sales@nestfoodsltd.com
HR_NOTIFICATION_EMAIL=hrsupport@nestfoodsltd.com
ADMIN_NOTIFICATION_EMAIL=adminsupport@nestfoodsltd.com

SENTRY_ENVIRONMENT=staging
